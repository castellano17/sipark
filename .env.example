# Configuración de Base de Datos (Opcional)
# Si no se especifica, se usará db-config.json

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ludoteca_pos
DB_USER=ludoteca_user
DB_PASSWORD=tu_password_seguro

# Modo de base de datos
# sqlite = Base de datos local (por defecto)
# postgresql = Base de datos cliente-servidor
DB_MODE=sqlite
